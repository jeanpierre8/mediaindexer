{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../src",
    "distDir": "../src",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Media Indexer",
    "version": "1.0.1"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": true,
        "open": true,
        "save": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": [
          "http://127.0.0.1:8765/*",
          "http://localhost:8765/*"
        ]
      },
      "shell": {
        "all": false,
        "execute": true,
        "sidecar": true,
        "scope": [
          {
            "name": "binaries/media-indexer-api",
            "sidecar": true,
            "args": false
          }
        ]
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.mediaindexer.app",
      "icon": [
        "icons/icon.ico"
      ],
      "externalBin": [
        "binaries/media-indexer-api"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Media Indexer",
        "width": 1200,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}